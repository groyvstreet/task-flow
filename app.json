{
  "expo": {
    "name": "TaskFlow",
    "slug": "task-flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "taskflow",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.kraken_born.taskflow",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk"
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kraken-born.taskflow",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TaskFlow uses location to show task pins on the map.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-splash-screen",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TaskFlow to access your photos for task attachments."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk",
          "iosGoogleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow TaskFlow to use location for address geocoding and map pins."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "googleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk",
      "eas": {
        "projectId": "b2fe303b-4611-4a68-85c2-15ca970cc54d"
      }
    }
  }
}
