{
  "expo": {
    "name": "TaskFlow",
    "slug": "task-flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "taskflow",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.kraken-born.test",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TaskFlow uses location for address geocoding and map pins."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F5F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kraken_born.test",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F5F5",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "dark": {
            "backgroundColor": "#0A0A0A"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk",
          "iosGoogleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow TaskFlow to use location for address geocoding and map pins."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#171717"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "googleMapsApiKey": "AIzaSyAcu58a39__y4GPpDcU5lYehG1A9aE-Wmk",
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "b2fe303b-4611-4a68-85c2-15ca970cc54d"
      }
    }
  }
}
